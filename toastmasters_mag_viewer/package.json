{
  "name": "toastmasters-magazine-viewer",
  "version": "1.0.0",
  "description": "Portable viewer for Toastmasters Magazine archives",
  "main": "main.js",
  "author": "Richard Teel",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win nsis"
  },
  "build": {
    "appId": "com.toastmasters.magazineviewer",
    "productName": "Toastmasters Magazine Viewer",
    "copyright": "Copyright © 2026 TeelSys LLC",
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "Toastmasters Magazine Viewer.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "artifactName": "ToastmastersViewer-Setup.exe"
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "styles.css"
    ]
  },
  "devDependencies": {
    "electron": "^40.0.0",
    "electron-builder": "^23.0.6"
  },
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "pdf-parse": "^2.4.5"
  }
}
